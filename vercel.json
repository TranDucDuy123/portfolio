{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/tuvanhosting",
      "destination": "./chien-luoc/tu-van-hosting.html"
    },
    {
      "source": "/gui-yeu-cau",
      "destination": "/brief.html"
    },
    {
      "source": "/ve-duc-duy",
      "destination": "/ve-duc-duy.html"
    },
    {
      "source": "/huong-dan",
      "destination": "/order-guide.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}